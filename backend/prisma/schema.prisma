generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CLIENT
  OWNER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id               Int       @id @default(autoincrement())
  fullName         String
  email            String    @unique
  password         String
  role             UserRole
  createdAt        DateTime  @default(now())
  resetToken       String?
  resetTokenExpiry DateTime?

  salons    Salon[]    @relation("OwnerSalons")
  bookings  Booking[]  @relation("ClientBookings")
  reviews   Review[]
  favorites Favorite[]
}

model Salon {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  address     String?
  imageUrl    String?
  ownerId     Int
  createdAt   DateTime @default(now())

  owner       User         @relation("OwnerSalons", fields: [ownerId], references: [id], onDelete: Cascade)
  services    Service[]
  products    Product[]
  bookings    Booking[]
  reviews     Review[]
  favorites   Favorite[]
  specialists Specialist[]
}

model Service {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  durationMin Int
  salonId     Int
  createdAt   DateTime @default(now())

  salon              Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  specialistServices SpecialistService[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  salonId     Int
  createdAt   DateTime @default(now())

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)
}

model Booking {
  id           Int           @id @default(autoincrement())
  clientId     Int
  salonId      Int
  serviceId    Int
  specialistId Int?
  bookingDate  String
  bookingTime  String
  totalPrice   Float
  status       BookingStatus @default(PENDING)
  notes        String?
  createdAt    DateTime      @default(now())

  client     User        @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  salon      Salon       @relation(fields: [salonId], references: [id], onDelete: Cascade)
  service    Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  specialist Specialist? @relation(fields: [specialistId], references: [id])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  userId    Int
  salonId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  salonId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([userId, salonId])
}

model Specialist {
  id        Int              @id @default(autoincrement())
  fullName  String
  title     String?
  bio       String?
  photoUrl  String?
  salonId   Int
  createdAt DateTime         @default(now())
  works     SpecialistWork[]

  salon              Salon               @relation(fields: [salonId], references: [id], onDelete: Cascade)
  bookings           Booking[]
  specialistServices SpecialistService[]
  workStartTime      String?             @default("09:00")
  workEndTime        String?             @default("18:00")
  workDays           String?             @default("1,2,3,4,5,6")
}

model SpecialistWork {
  id           Int      @id @default(autoincrement())
  imageUrl     String
  caption      String?
  specialistId Int
  createdAt    DateTime @default(now())

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
}

model SpecialistService {
  id           Int @id @default(autoincrement())
  specialistId Int
  serviceId    Int

  specialist Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  service    Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([specialistId, serviceId])
}
